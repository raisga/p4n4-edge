# ==============================================================================
# Edge Impulse Stack Environment Configuration
# ==============================================================================
# Copy this file to .env and customize as needed:
#   cp .env.example .env
# IMPORTANT: Never commit .env — it contains secrets.
# ==============================================================================

# ------------------------------------------------------------------------------
# Edge Impulse
# ------------------------------------------------------------------------------

# API key for Edge Impulse cloud features (optional — only needed for cloud sync)
# Get your key at: https://studio.edgeimpulse.com → project → Dashboard → Keys
EI_API_KEY=

# Filename of the .eim model to run (place the file in edge-impulse/models/)
# Download from Edge Impulse Studio: Deployment → Linux (AARCH64 or x86_64)
EI_MODEL_FILE=model.eim

# ------------------------------------------------------------------------------
# MQTT (shared with p4n4-iot — must match values in p4n4-iot .env)
# ------------------------------------------------------------------------------

# Broker host — use 'p4n4-mqtt' when running alongside p4n4-iot on p4n4-net
MQTT_HOST=p4n4-mqtt
MQTT_PORT=1883

# Credentials — leave blank if Mosquitto runs without authentication
MQTT_USER=
MQTT_PASSWORD=

# Topics
MQTT_TOPIC_INPUT=sensors/raw
MQTT_TOPIC_RESULTS=inference/results

# ------------------------------------------------------------------------------
# InfluxDB (shared with p4n4-iot — must match values in p4n4-iot .env)
# ------------------------------------------------------------------------------
INFLUXDB_TOKEN=p4n4-stack-token
INFLUXDB_ORG=ming
INFLUXDB_BUCKET_AI_EVENTS=ai_events

# ------------------------------------------------------------------------------
# General
# ------------------------------------------------------------------------------
TZ=UTC
